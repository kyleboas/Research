# ChatGPT subscription OAuth — run once to authenticate:
#   python main.py --login
# Credentials are stored at ~/.codex/auth.json and refreshed automatically.

# Postgres — on Railway, set one of these reference variables:
#   DATABASE_URL=${{pgvector.DATABASE_URL}}
#   DATABASE_PRIVATE_URL=${{pgvector.DATABASE_PRIVATE_URL}}
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# TranscriptAPI for YouTube transcripts
TRANSCRIPT_API_KEY=...

# Optional model overrides
OPENAI_LEAD_MODEL=o3
OPENAI_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small
